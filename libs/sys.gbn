-- System library for GBN

@from .sys.py @as ___sys

func _sys_platform() -> any
  return $___sys.platform_name()
end

func _sys_os_name() -> str
  return $___sys.os_name()
end

func _sys_cpu_count() -> int
  return $___sys.cpu_count()
end

-- Environ variable
func _sys_env(_name: str, _default: str) -> str
  return $___sys.env(_name, _default)
end

func _sys_exit() -> NULL
  $___sys._exit()
end
